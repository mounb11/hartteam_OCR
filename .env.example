# Kopieer dit bestand naar .env en vul de waarden in.
# .env staat NOOIT in git (staat in .gitignore).

# ── Tesseract ──────────────────────────────────────────────────────────────────
# Pad naar de Tesseract binary
# macOS (Homebrew): /opt/homebrew/bin/tesseract
# Linux:            /usr/bin/tesseract
TESSERACT_CMD=/opt/homebrew/bin/tesseract

# ── Ollama ─────────────────────────────────────────────────────────────────────
# URL van de lokale Ollama server (standaard: localhost)
OLLAMA_BASE_URL=http://localhost:11434

# Model te gebruiken (installeren met: ollama pull qwen2.5:14b)
OLLAMA_MODEL=qwen2.5:14b

# ── HiX / ChipSoft FHIR API ────────────────────────────────────────────────────
# On-premise HiX FHIR endpoint (vraag dit op bij jullie IT-afdeling / ChipSoft)
HIX_FHIR_BASE_URL=http://hix-server/jouw-instelling/fhir/R4

# Bearer token voor HiX authenticatie
HIX_API_TOKEN=
